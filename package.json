{
  "name": "clusterag",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:js && node scripts/prepare-public.mjs",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/styles/tailwind.input.css -o ./src/styles/tailwind.generated.css --minify",
    "build:js": "esbuild src/app/main.jsx --bundle --outfile=src/app/main.compiled.js --format=esm --external:react --external:react-dom/client --external:lucide-react --external:@capacitor/app --external:firebase/auth --external:firebase/firestore --external:/src/app/config/firebase.js --external:/src/app/constants/app.constants.js --external:/src/app/utils/date.js --legal-comments=none",
    "dev": "node server/index.js",
    "start": "node server/index.js",
    "mobile:sync": "npm run build && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.8.0",
    "knex": "^3.1.0",
    "mysql2": "^3.14.1",
    "nodemailer": "^6.10.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "esbuild": "^0.25.5",
    "tailwindcss": "^3.4.17"
  }
}
