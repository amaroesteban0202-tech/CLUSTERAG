{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "functions": {
    "api/health.js": {
      "includeFiles": "server/**"
    },
    "api/auth-entry.js": {
      "includeFiles": "server/**"
    },
    "api/collections-entry.js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth-entry"
    },
    {
      "source": "/api/collections/:path*",
      "destination": "/api/collections-entry"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/:path((?!api/|src/|favicon\\.svg|app-config\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
