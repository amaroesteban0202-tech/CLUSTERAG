{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "functions": {
    "api/health.js": {
      "includeFiles": "server/**"
    },
    "api/auth-entry.js": {
      "includeFiles": "server/**"
    },
    "api/collections-entry.js": {
      "includeFiles": "server/**"
    },
    "api/cron-entry.js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/google/:path*",
      "destination": "/api/auth-entry"
    },
    {
      "source": "/api/auth/firebase/:path*",
      "destination": "/api/auth-entry"
    },
    {
      "source": "/api/auth/email/:path*",
      "destination": "/api/auth-entry"
    },
    {
      "source": "/api/auth/token/:path*",
      "destination": "/api/auth-entry"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth-entry"
    },
    {
      "source": "/api/collections/:path*",
      "destination": "/api/collections-entry"
    },
    {
      "source": "/api/cron/:path*",
      "destination": "/api/cron-entry"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/:path((?!api/|src/|favicon\\.svg|app-config\\.js).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/management-task-reminders",
      "schedule": "*/5 * * * *"
    }
  ]
}
